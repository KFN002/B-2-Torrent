{
  "name": "b2-vpn-client",
  "version": "1.0.0",
  "description": "B2 VPN Client - local-first VPN and proxy client with safer desktop defaults",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --x64 --arm64",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:linux": "electron-builder --linux --x64",
    "pack": "electron-builder --dir",
    "portable": "electron-builder --win portable --linux AppImage"
  },
  "build": {
    "appId": "com.b2torrent.vpnclient",
    "productName": "B2 VPN Client",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": ["main.js", "preload.js", "renderer.js", "index.html", "styles.css"],
    "asar": true,
    "win": {
      "target": ["nsis", "portable", "zip"],
      "artifactName": "B2-VPN-Client-${version}-${arch}.${ext}",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "artifactName": "B2-VPN-Client-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Network"
    }
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "socks": "^2.8.8"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  }
}
