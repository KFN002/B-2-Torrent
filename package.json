{
  "name": "b2torrent",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "gen-env": "node scripts/gen-env.mjs",
    "dev": "docker compose up --build",
    "build": "docker compose build",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "health": "bash scripts/health-check.sh",
    "frontend:dev": "pnpm --dir frontend dev",
    "frontend:build": "pnpm --dir frontend build",
    "frontend:lint": "pnpm --dir frontend lint",
    "backend:dev": "cd backend && go run ./cmd/server",
    "backend:test": "cd backend && go test ./...",
    "file-viewer:dev": "cd file-viewer && npm start",
    "file-viewer:build": "cd file-viewer && npm run build",
    "file-viewer:build:linux": "cd file-viewer && npm run build:linux"
  }
}
