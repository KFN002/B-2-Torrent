{
  "name": "b2-secure-browser",
  "version": "1.0.0",
  "description": "Privacy-focused browser with ephemeral sessions and local trace reduction",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --x64 --arm64",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:linux": "electron-builder --linux --x64",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "portable": "electron-builder --win portable --linux AppImage"
  },
  "build": {
    "appId": "com.b2torrent.securebrowser",
    "productName": "B2 Secure Browser",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": ["main.js", "preload.js", "renderer.js", "search-engine.js", "index.html", "styles.css"],
    "asar": true,
    "win": {
      "target": ["nsis", "portable", "zip"],
      "artifactName": "B2-Secure-Browser-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "artifactName": "B2-Secure-Browser-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "tar.gz"],
      "category": "Network",
      "artifactName": "B2-Secure-Browser-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "B2-Secure-Browser-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "axios": "^1.16.0",
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  }
}
