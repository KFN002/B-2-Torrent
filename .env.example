COMPOSE_PROJECT_NAME=b2torrent
HTTP_PORT=80
FRONTEND_PORT=3000
BACKEND_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
TOR_SOCKS_PORT=9050
DOWNLOAD_DIR=./downloads
POSTGRES_USER=torrentuser
POSTGRES_DB=torrentdb
DB_PASSWORD=replace-with-generated-secret
RABBITMQ_USER=b2t_admin
RABBITMQ_PASS=replace-with-generated-secret
TOR_ENABLED=true
PROXY_CHAIN=tor:9050
NO_LOGS_MODE=true
OBFUSCATE_TRAFFIC=true
LOG_LEVEL=warn
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1,http://127.0.0.1:3000
NEXT_PUBLIC_ENABLE_EXTERNAL_LEAK_CHECKS=false
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-generated-publishable-key
SUPABASE_INTERNAL_URL=http://host.docker.internal:8000
SUPABASE_SECRET_KEY=replace-with-generated-secret-key
